<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.controllers.AdminController"
            style="-fx-background-color: #F0F2F5;">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--                        HEADER                          -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #1A1F2E;
                     -fx-min-height: 60; -fx-max-height: 60;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 3);">

            <HBox alignment="CENTER"
                  style="-fx-min-width: 200; -fx-max-width: 200;
                         -fx-min-height: 60; -fx-max-height: 60;
                         -fx-background-color: #141824; -fx-padding: 0 20 0 20;">
                <Label text="⬡  Rentify"
                       style="-fx-text-fill: #FFFFFF; -fx-font-size: 19px;
                              -fx-font-weight: bold;
                              -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
            </HBox>

            <Label text="Admin Dashboard"
                   style="-fx-text-fill: #64748B; -fx-font-size: 14px;
                          -fx-font-family: 'Segoe UI', sans-serif;
                          -fx-padding: 0 0 0 24;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Admin badge -->
            <HBox alignment="CENTER" spacing="10"
                  style="-fx-padding: 8 14 8 14; -fx-background-color: #252B3B;
                         -fx-background-radius: 30;">
                <StackPane style="-fx-min-width: 34; -fx-min-height: 34;
                                  -fx-max-width: 34; -fx-max-height: 34;
                                  -fx-background-color: #4F7BF7;
                                  -fx-background-radius: 17;">
                    <Label text="A" style="-fx-text-fill: white; -fx-font-size: 14px;
                                          -fx-font-weight: bold;"/>
                </StackPane>
                <VBox spacing="1">
                    <Label text="Admin"
                           style="-fx-text-fill: #E2E8F0; -fx-font-size: 13px;
                                  -fx-font-weight: bold;
                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                    <Label text="Super Administrator"
                           style="-fx-text-fill: #475569; -fx-font-size: 10px;
                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                </VBox>
            </HBox>

            <Button text="—" onAction="#onMinimize"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #94A3B8;
                           -fx-font-size: 16px; -fx-font-weight: bold;
                           -fx-padding: 0 10 0 10;
                           -fx-cursor: hand;"/>
            <Button text="☐" onAction="#onMaximize"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #94A3B8;
                           -fx-font-size: 16px; -fx-font-weight: bold;
                           -fx-padding: 0 10 0 10;
                           -fx-cursor: hand;"/>
            <Button text="✕" onAction="#onClose"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #94A3B8;
                           -fx-font-size: 18px; -fx-font-weight: bold;
                           -fx-padding: 0 20 0 16;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--          CENTER — TabPane side=LEFT as sidebar         -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <center>
        <TabPane side="LEFT"
                 tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #1A1F2E;
                        -fx-tab-min-width: 180; -fx-tab-max-width: 180;
                        -fx-tab-min-height: 40; -fx-tab-max-height: 40;
                        -fx-open-tab-animation: NONE;
                        -fx-close-tab-animation: NONE;
                        -fx-font-size: 11px;">

            <!-- ══════════════════════════════════════════════ -->
            <!--            TAB 1 — MANAGE USERS               -->
            <!-- ══════════════════════════════════════════════ -->
            <Tab text="👥  Manage Users">
                <VBox spacing="20"
                      style="-fx-background-color: #F0F2F5; -fx-padding: 28;">

                    <VBox spacing="3">
                        <Label text="User Management"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;
                                      -fx-text-fill: #1A1F2E;
                                      -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                        <Label text="View, edit, deactivate and remove registered users"
                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                    </VBox>

                    <!-- Search bar -->
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color: #FFFFFF; -fx-padding: 10 16 10 16;
                                 -fx-background-radius: 10;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                        <Label text="🔍" style="-fx-font-size: 14px;"/>
                        <TextField fx:id="userSearchField"
                                   promptText="Search by name or email..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-color: transparent; -fx-font-size: 13px;
                                          -fx-font-family: 'Segoe UI', sans-serif;
                                          -fx-text-fill: #1A1F2E; -fx-prompt-text-fill: #94A3B8;"/>
                        <Button text="Search" onAction="#onSearchUsers"
                                style="-fx-background-color: #4F7BF7; -fx-text-fill: white;
                                       -fx-font-size: 12px; -fx-font-weight: bold;
                                       -fx-font-family: 'Segoe UI', sans-serif;
                                       -fx-padding: 8 20 8 20; -fx-background-radius: 7;
                                       -fx-cursor: hand;"/>
                        <Button text="↺  Refresh" onAction="#onRefreshUsers"
                                style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569;
                                       -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;
                                       -fx-padding: 8 16 8 16; -fx-background-radius: 7;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                                      -fx-border-color: transparent;
                                      -fx-table-cell-border-color: #F1F5F9;">
                        <columns>
                            <TableColumn fx:id="userIdCol"     text="ID"      prefWidth="60"/>
                            <TableColumn fx:id="userNameCol"   text="Name"    prefWidth="150"/>
                            <TableColumn fx:id="userEmailCol"  text="Email"   prefWidth="200"/>
                            <TableColumn fx:id="userPhoneCol"  text="Phone"   prefWidth="130"/>
                            <TableColumn fx:id="userRoleCol"   text="Role"    prefWidth="90"/>
                            <TableColumn fx:id="userActionCol" text="Actions" prefWidth="240"/>
                        </columns>
                        <placeholder>
                            <Label text="No users found."
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </placeholder>
                    </TableView>

                </VBox>
            </Tab>

            <!-- ══════════════════════════════════════════════ -->
            <!--         TAB 2 — MODERATE LISTINGS             -->
            <!-- ══════════════════════════════════════════════ -->
            <Tab text="🗂  Moderate Listings">
                <HBox style="-fx-background-color: #F0F2F5;">

                    <!-- LEFT MAIN COLUMN -->
                    <VBox spacing="20" HBox.hgrow="ALWAYS"
                          style="-fx-padding: 28 16 28 28;">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="3">
                                <Label text="Moderate Listings"
                                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                                              -fx-text-fill: #1A1F2E;
                                              -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                                <Label text="Review each pending listing and approve or reject it with a reason"
                                       style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                              -fx-font-family: 'Segoe UI', sans-serif;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="↺  Refresh Queue" onAction="#onRefreshListings"
                                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569;
                                           -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;
                                           -fx-padding: 9 18 9 18; -fx-background-radius: 8;
                                           -fx-cursor: hand;"/>
                        </HBox>

                        <!-- Stat cards -->
                        <HBox spacing="12">
                            <HBox HBox.hgrow="ALWAYS" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: #FFFFFF; -fx-padding: 16 18 16 18;
                                         -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                                <StackPane style="-fx-min-width: 40; -fx-min-height: 40;
                                                  -fx-max-width: 40; -fx-max-height: 40;
                                                  -fx-background-color: #FEF3C7;
                                                  -fx-background-radius: 9;">
                                    <Label text="⏳" style="-fx-font-size: 18px;"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label fx:id="pendingCountLabel" text="—"
                                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                                  -fx-text-fill: #D97706;
                                                  -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                                    <Label text="Pending"
                                           style="-fx-text-fill: #92400E; -fx-font-size: 11px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </VBox>
                            </HBox>
                            <HBox HBox.hgrow="ALWAYS" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: #FFFFFF; -fx-padding: 16 18 16 18;
                                         -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                                <StackPane style="-fx-min-width: 40; -fx-min-height: 40;
                                                  -fx-max-width: 40; -fx-max-height: 40;
                                                  -fx-background-color: #DCFCE7;
                                                  -fx-background-radius: 9;">
                                    <Label text="✅" style="-fx-font-size: 18px;"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label fx:id="approvedTodayLabel" text="—"
                                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                                  -fx-text-fill: #16A34A;
                                                  -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                                    <Label text="Approved Today"
                                           style="-fx-text-fill: #166534; -fx-font-size: 11px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </VBox>
                            </HBox>
                            <HBox HBox.hgrow="ALWAYS" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: #FFFFFF; -fx-padding: 16 18 16 18;
                                         -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                                <StackPane style="-fx-min-width: 40; -fx-min-height: 40;
                                                  -fx-max-width: 40; -fx-max-height: 40;
                                                  -fx-background-color: #FEE2E2;
                                                  -fx-background-radius: 9;">
                                    <Label text="❌" style="-fx-font-size: 18px;"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label fx:id="rejectedTodayLabel" text="—"
                                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                                  -fx-text-fill: #DC2626;
                                                  -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                                    <Label text="Rejected Today"
                                           style="-fx-text-fill: #7F1D1D; -fx-font-size: 11px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </VBox>
                            </HBox>
                            <HBox HBox.hgrow="ALWAYS" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color: #FFFFFF; -fx-padding: 16 18 16 18;
                                         -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                                <StackPane style="-fx-min-width: 40; -fx-min-height: 40;
                                                  -fx-max-width: 40; -fx-max-height: 40;
                                                  -fx-background-color: #EDE9FE;
                                                  -fx-background-radius: 9;">
                                    <Label text="📋" style="-fx-font-size: 18px;"/>
                                </StackPane>
                                <VBox spacing="2">
                                    <Label fx:id="totalReviewedLabel" text="—"
                                           style="-fx-font-size: 24px; -fx-font-weight: bold;
                                                  -fx-text-fill: #7C3AED;
                                                  -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                                    <Label text="Total Reviewed"
                                           style="-fx-text-fill: #4C1D95; -fx-font-size: 11px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </VBox>
                            </HBox>
                        </HBox>

                        <!-- Search + filter bar -->
                        <HBox spacing="10" alignment="CENTER_LEFT"
                              style="-fx-background-color: #FFFFFF; -fx-padding: 10 14 10 14;
                                     -fx-background-radius: 10;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
                            <Label text="🔍" style="-fx-font-size: 13px;"/>
                            <TextField fx:id="listingSearchField"
                                       promptText="Search by title or owner..."
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 13px;
                                              -fx-font-family: 'Segoe UI', sans-serif;
                                              -fx-text-fill: #1A1F2E; -fx-prompt-text-fill: #94A3B8;"/>
                            <ComboBox fx:id="listingStatusFilter" promptText="All Status"
                                      style="-fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;
                                             -fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;
                                             -fx-background-radius: 6; -fx-border-radius: 6;
                                             -fx-cursor: hand;"/>
                            <Button text="Search" onAction="#onSearchListings"
                                    style="-fx-background-color: #4F7BF7; -fx-text-fill: white;
                                           -fx-font-size: 12px; -fx-font-weight: bold;
                                           -fx-font-family: 'Segoe UI', sans-serif;
                                           -fx-padding: 8 20 8 20; -fx-background-radius: 7;
                                           -fx-cursor: hand;"/>
                        </HBox>

                        <!-- Listings Table -->
                        <TableView fx:id="listingsTable" VBox.vgrow="ALWAYS"
                                   style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                                          -fx-border-color: transparent;
                                          -fx-table-cell-border-color: #F1F5F9;">
                            <columns>
                                <TableColumn fx:id="listingIdCol"       text="ID"        prefWidth="50"/>
                                <TableColumn fx:id="listingTitleCol"    text="Title"     prefWidth="160"/>
                                <TableColumn fx:id="listingOwnerCol"    text="Owner"     prefWidth="120"/>
                                <TableColumn fx:id="listingCategoryCol" text="Category"  prefWidth="100"/>
                                <TableColumn fx:id="listingDateCol"     text="Submitted" prefWidth="100"/>
                                <TableColumn fx:id="listingStatusCol"   text="Status"    prefWidth="90"/>
                                <TableColumn fx:id="listingActionCol"   text="Actions"   prefWidth="160"/>
                            </columns>
                            <placeholder>
                                <VBox alignment="CENTER" spacing="8">
                                    <Label text="🎉" style="-fx-font-size: 28px;"/>
                                    <Label text="No pending listings — queue is clear."
                                           style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </VBox>
                            </placeholder>
                        </TableView>

                        <!-- Review Panel -->
                        <VBox fx:id="reviewPanel" spacing="0"
                              style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                            <HBox alignment="CENTER_LEFT" spacing="10"
                                  style="-fx-background-color: #1A1F2E;
                                         -fx-padding: 12 18 12 18;
                                         -fx-background-radius: 12 12 0 0;">
                                <Label text="📄" style="-fx-font-size: 14px;"/>
                                <Label text="Review Selected Listing"
                                       style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px;
                                              -fx-font-weight: bold;
                                              -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="selectedListingIdLabel" text=""
                                       style="-fx-text-fill: #475569; -fx-font-size: 11px;
                                              -fx-font-family: 'Segoe UI', sans-serif;"/>
                            </HBox>
                            <HBox spacing="0">
                                <VBox spacing="10"
                                      style="-fx-padding: 16 20 16 20; -fx-min-width: 260;">
                                    <Label text="LISTING DETAILS"
                                           style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    <HBox spacing="8">
                                        <Label text="Title:"
                                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                                      -fx-min-width: 70;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                        <Label fx:id="selectedListingTitle" text="—"
                                               style="-fx-text-fill: #1A1F2E; -fx-font-size: 12px;
                                                      -fx-font-weight: bold;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    </HBox>
                                    <HBox spacing="8">
                                        <Label text="Owner:"
                                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                                      -fx-min-width: 70;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                        <Label fx:id="selectedListingOwner" text="—"
                                               style="-fx-text-fill: #1A1F2E; -fx-font-size: 12px;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    </HBox>
                                    <HBox spacing="8">
                                        <Label text="Category:"
                                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                                      -fx-min-width: 70;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                        <Label fx:id="selectedListingCategory" text="—"
                                               style="-fx-text-fill: #1A1F2E; -fx-font-size: 12px;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    </HBox>
                                    <HBox spacing="8">
                                        <Label text="Submitted:"
                                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                                      -fx-min-width: 70;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                        <Label fx:id="selectedListingDate" text="—"
                                               style="-fx-text-fill: #1A1F2E; -fx-font-size: 12px;
                                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    </HBox>
                                </VBox>
                                <Separator orientation="VERTICAL" style="-fx-background-color: #F1F5F9;"/>
                                <VBox spacing="10" alignment="CENTER"
                                      style="-fx-padding: 16 24 16 24; -fx-min-width: 180;">
                                    <Label text="APPROVE LISTING"
                                           style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    <Label text="Listing will become visible to all renters."
                                           wrapText="true"
                                           style="-fx-text-fill: #64748B; -fx-font-size: 11px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;
                                                  -fx-text-alignment: CENTER;"/>
                                    <Button fx:id="approveBtn" text="✓   Approve Listing"
                                            onAction="#onApproveListing" maxWidth="Infinity"
                                            style="-fx-background-color: #16A34A; -fx-text-fill: white;
                                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                                   -fx-font-family: 'Segoe UI', sans-serif;
                                                   -fx-padding: 11 0 11 0;
                                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                                </VBox>
                                <Separator orientation="VERTICAL" style="-fx-background-color: #F1F5F9;"/>
                                <VBox spacing="10" HBox.hgrow="ALWAYS"
                                      style="-fx-padding: 16 20 16 20;">
                                    <Label text="REJECT LISTING"
                                           style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    <Label text="Provide a reason so the owner knows what to fix:"
                                           style="-fx-text-fill: #64748B; -fx-font-size: 11px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    <TextArea fx:id="rejectionReasonField"
                                              promptText="e.g. Missing price details, unclear photos, prohibited item..."
                                              prefRowCount="3" wrapText="true"
                                              style="-fx-background-color: #FFF7F7;
                                                     -fx-border-color: #FCA5A5;
                                                     -fx-border-radius: 7; -fx-background-radius: 7;
                                                     -fx-border-width: 1; -fx-font-size: 12px;
                                                     -fx-font-family: 'Segoe UI', sans-serif;
                                                     -fx-text-fill: #1A1F2E;
                                                     -fx-prompt-text-fill: #94A3B8;"/>
                                    <Button fx:id="rejectBtn" text="✗   Reject Listing"
                                            onAction="#onRejectListing" maxWidth="Infinity"
                                            style="-fx-background-color: #DC2626; -fx-text-fill: white;
                                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                                   -fx-font-family: 'Segoe UI', sans-serif;
                                                   -fx-padding: 11 0 11 0;
                                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                    </VBox>

                    <!-- RIGHT — AUDIT LOG -->
                    <VBox spacing="0"
                          style="-fx-min-width: 260; -fx-max-width: 260;
                                 -fx-padding: 28 28 28 0;">
                        <HBox alignment="CENTER_LEFT" spacing="8"
                              style="-fx-background-color: #1A1F2E;
                                     -fx-padding: 14 16 14 16;
                                     -fx-background-radius: 12 12 0 0;">
                            <Label text="🗒" style="-fx-font-size: 14px;"/>
                            <Label text="Audit Log"
                                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Clear" onAction="#onClearAuditLog"
                                    style="-fx-background-color: #252B3B; -fx-text-fill: #64748B;
                                           -fx-font-size: 10px; -fx-font-family: 'Segoe UI', sans-serif;
                                           -fx-padding: 4 10 4 10; -fx-background-radius: 4;
                                           -fx-cursor: hand;"/>
                        </HBox>
                        <ListView fx:id="auditLogList" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: #FFFFFF;
                                         -fx-background-radius: 0 0 12 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                                         -fx-border-color: transparent; -fx-font-size: 11px;
                                         -fx-font-family: 'Segoe UI', sans-serif;">
                            <placeholder>
                                <Label text="No actions logged yet."
                                       style="-fx-text-fill: #CBD5E1; -fx-font-size: 12px;
                                              -fx-font-family: 'Segoe UI', sans-serif;"/>
                            </placeholder>
                        </ListView>
                    </VBox>

                </HBox>
            </Tab>

            <!-- ══════════════════════════════════════════════ -->
            <!--         TAB 3 — VIEW TRANSACTIONS             -->
            <!-- ══════════════════════════════════════════════ -->
            <Tab text="💳  View Transactions">
                <VBox spacing="20"
                      style="-fx-background-color: #F0F2F5; -fx-padding: 28;">

                    <VBox spacing="3">
                        <Label text="Transactions"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;
                                      -fx-text-fill: #1A1F2E;
                                      -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                        <Label text="View and filter all rental transactions across the platform"
                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                    </VBox>

                    <HBox spacing="12">
                        <HBox HBox.hgrow="ALWAYS" spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: #FFFFFF; -fx-padding: 14 18;
                                     -fx-background-radius: 12;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                            <Label text="📊" style="-fx-font-size: 18px;"/>
                            <Label fx:id="statsLabel"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;
                                          -fx-text-fill: #1A1F2E;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="-fx-background-color: #FFFFFF; -fx-padding: 10 14;
                                 -fx-background-radius: 10;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">
                        <Label text="🔍" style="-fx-font-size: 13px;"/>
                        <TextField fx:id="txSearchField"
                                   promptText="Search by renter, owner or product..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-color: transparent; -fx-font-size: 13px;
                                          -fx-font-family: 'Segoe UI', sans-serif;
                                          -fx-text-fill: #1A1F2E; -fx-prompt-text-fill: #94A3B8;"/>
                        <ComboBox fx:id="txStatusFilter" promptText="All Status"
                                  style="-fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;
                                         -fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;
                                         -fx-background-radius: 6; -fx-border-radius: 6;
                                         -fx-cursor: hand;"/>
                        <Button text="Search" onAction="#onSearchTransactions"
                                style="-fx-background-color: #4F7BF7; -fx-text-fill: white;
                                       -fx-font-size: 12px; -fx-font-weight: bold;
                                       -fx-font-family: 'Segoe UI', sans-serif;
                                       -fx-padding: 8 20; -fx-background-radius: 7;
                                       -fx-cursor: hand;"/>
                        <Button text="&#8635;  Refresh" onAction="#onRefreshTransactions"
                                style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569;
                                       -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;
                                       -fx-padding: 8 16; -fx-background-radius: 7;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <TableView fx:id="transactionsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                                      -fx-border-color: transparent;
                                      -fx-table-cell-border-color: #F1F5F9;">
                        <columns>
                            <TableColumn fx:id="txIdCol"        text="Tx ID"      prefWidth="65"/>
                            <TableColumn fx:id="txBookingIdCol" text="Booking ID" prefWidth="85"/>
                            <TableColumn fx:id="txProductCol"   text="Product"    prefWidth="150"/>
                            <TableColumn fx:id="txRenterCol"    text="Renter"     prefWidth="130"/>
                            <TableColumn fx:id="txOwnerCol"     text="Owner"      prefWidth="130"/>
                            <TableColumn fx:id="txAmountCol"    text="Amount"     prefWidth="90"/>
                            <TableColumn fx:id="txStatusCol"    text="Status"     prefWidth="90"/>
                            <TableColumn fx:id="txCreatedAtCol" text="Created At" prefWidth="130"/>
                        </columns>
                        <placeholder>
                            <VBox alignment="CENTER" spacing="8">
                                <Label text="🔍" style="-fx-font-size: 28px;"/>
                                <Label text="No transactions found."
                                       style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;
                                              -fx-font-family: 'Segoe UI', sans-serif;"/>
                            </VBox>
                        </placeholder>
                    </TableView>

                    <VBox fx:id="txDetailPanel" spacing="0"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: #1A1F2E; -fx-padding: 12 18;
                                     -fx-background-radius: 12 12 0 0;">
                            <Label text="💳" style="-fx-font-size: 14px;"/>
                            <Label text="Transaction Details"
                                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="txDetailIdLabel" text=""
                                   style="-fx-text-fill: #475569; -fx-font-size: 11px;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>
                        <VBox spacing="10" style="-fx-padding: 16 20;">
                            <Label text="FULL DETAILS"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                            <Label fx:id="detailsLabel" wrapText="true"
                                   style="-fx-font-size: 13px; -fx-text-fill: #1A1F2E;
                                          -fx-font-family: 'Segoe UI', sans-serif;
                                          -fx-line-spacing: 4;"/>
                        </VBox>
                    </VBox>

                </VBox>
            </Tab>

            <!-- ══════════════════════════════════════════════ -->
            <!--         TAB 4 — RENTAL HISTORY                -->
            <!-- ══════════════════════════════════════════════ -->
            <Tab text="📜  Rental History">
                <VBox spacing="20"
                      style="-fx-background-color: #F0F2F5; -fx-padding: 28;">

                    <VBox spacing="3">
                        <Label text="Rental History"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;
                                      -fx-text-fill: #1A1F2E;
                                      -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                        <Label text="Track all rental activities across the platform"
                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                    </VBox>

                    <HBox spacing="16" VBox.vgrow="ALWAYS">

                        <!-- Left: Renter history -->
                        <VBox spacing="0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8"
                                  style="-fx-background-color: #1A1F2E;
                                         -fx-padding: 12 16;
                                         -fx-background-radius: 12 12 0 0;">
                                <Label text="📤" style="-fx-font-size: 13px;"/>
                                <Label text="Bookings Done by Renters"
                                       style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px;
                                              -fx-font-weight: bold;
                                              -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                            </HBox>
                            <ListView fx:id="renterHistoryList" VBox.vgrow="ALWAYS" prefHeight="350"
                                      style="-fx-background-color: #FFFFFF;
                                             -fx-background-radius: 0 0 12 12;
                                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                                             -fx-border-color: transparent;
                                             -fx-font-size: 12px;
                                             -fx-font-family: 'Segoe UI', sans-serif;">
                                <placeholder>
                                    <Label text="No renter bookings found."
                                           style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </placeholder>
                            </ListView>
                        </VBox>

                        <!-- Right: Owner history -->
                        <VBox spacing="0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="8"
                                  style="-fx-background-color: #1A1F2E;
                                         -fx-padding: 12 16;
                                         -fx-background-radius: 12 12 0 0;">
                                <Label text="📥" style="-fx-font-size: 13px;"/>
                                <Label text="Bookings Received by Owners"
                                       style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px;
                                              -fx-font-weight: bold;
                                              -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                            </HBox>
                            <ListView fx:id="ownerHistoryList" VBox.vgrow="ALWAYS" prefHeight="350"
                                      style="-fx-background-color: #FFFFFF;
                                             -fx-background-radius: 0 0 12 12;
                                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);
                                             -fx-border-color: transparent;
                                             -fx-font-size: 12px;
                                             -fx-font-family: 'Segoe UI', sans-serif;">
                                <placeholder>
                                    <Label text="No owner bookings found."
                                           style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;
                                                  -fx-font-family: 'Segoe UI', sans-serif;"/>
                                </placeholder>
                            </ListView>
                        </VBox>

                    </HBox>

                    <!-- Detail panel -->
                    <VBox spacing="0"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">

                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: #1A1F2E; -fx-padding: 12 18;
                                     -fx-background-radius: 12 12 0 0;">
                            <Label text="📄" style="-fx-font-size: 14px;"/>
                            <Label text="Booking Details"
                                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Click a booking above to see details"
                                   style="-fx-text-fill: #475569; -fx-font-size: 11px;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>

                        <ScrollPane fitToWidth="true" prefHeight="180"
                                    style="-fx-background-color: transparent;
                                           -fx-background: transparent;
                                           -fx-border-color: transparent;">
                            <VBox spacing="10" style="-fx-padding: 16 20;">
                                <Label text="FULL DETAILS"
                                       style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;
                                              -fx-font-family: 'Segoe UI', sans-serif;"/>
                                <Label fx:id="historyDetailsLabel"
                                       wrapText="true"
                                       text="Select a booking from the lists above to view full details here."
                                       style="-fx-font-size: 13px; -fx-text-fill: #1A1F2E;
                                              -fx-font-family: 'Segoe UI', sans-serif;
                                              -fx-line-spacing: 6;"/>
                            </VBox>
                        </ScrollPane>

                    </VBox>

                </VBox>
            </Tab>

            <!-- ══════════════════════════════════════════════ -->
            <!--         TAB 5 — STATISTICS AND REPORTS        -->
            <!-- ══════════════════════════════════════════════ -->
            <Tab text="📊  Reports">
                <VBox spacing="20"
                      style="-fx-background-color: #F0F2F5; -fx-padding: 28;">

                    <!-- Header -->
                    <VBox spacing="3">
                        <Label text="Statistics and Reports"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;
                                      -fx-text-fill: #1A1F2E;
                                      -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                        <Label text="Analyze platform performance and generate reports"
                               style="-fx-text-fill: #64748B; -fx-font-size: 12px;
                                      -fx-font-family: 'Segoe UI', sans-serif;"/>
                    </VBox>

                    <!-- Filter bar -->
                    <HBox spacing="12" alignment="CENTER_LEFT"
                          style="-fx-background-color: #FFFFFF; -fx-padding: 14 18;
                                 -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">

                        <VBox spacing="4">
                            <Label text="REPORT TYPE"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                            <ComboBox fx:id="reportTypeChoice" prefWidth="220"
                                      style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI', sans-serif;
                                             -fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;
                                             -fx-background-radius: 8; -fx-border-radius: 8;
                                             -fx-cursor: hand;"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="PERIOD"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                            <ComboBox fx:id="periodChoice" prefWidth="140"
                                      style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI', sans-serif;
                                             -fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0;
                                             -fx-background-radius: 8; -fx-border-radius: 8;
                                             -fx-cursor: hand;"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="📈  Generate Report"
                                onAction="#onGenerateReport"
                                style="-fx-background-color: #4F7BF7; -fx-text-fill: white;
                                       -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-font-family: 'Segoe UI', sans-serif;
                                       -fx-padding: 11 24 11 24; -fx-background-radius: 8;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Report output panel -->
                    <VBox spacing="0" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">

                        <!-- Panel header -->
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color: #1A1F2E; -fx-padding: 12 18;
                                     -fx-background-radius: 12 12 0 0;">
                            <Label text="📄" style="-fx-font-size: 14px;"/>
                            <Label fx:id="reportTitleLabel"
                                   text="Report Output"
                                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px;
                                          -fx-font-weight: bold;
                                          -fx-font-family: 'Segoe UI Semibold', sans-serif;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Select a report type and click Generate"
                                   style="-fx-text-fill: #475569; -fx-font-size: 11px;
                                          -fx-font-family: 'Segoe UI', sans-serif;"/>
                        </HBox>

                        <!-- Report text area -->
                        <TextArea fx:id="reportTextArea"
                                  VBox.vgrow="ALWAYS"
                                  prefHeight="480"
                                  editable="false"
                                  wrapText="true"
                                  style="-fx-font-family: 'Consolas', 'Courier New', monospace;
                                         -fx-font-size: 13px;
                                         -fx-text-fill: #1A1F2E;
                                         -fx-background-color: #F8FAFC;
                                         -fx-background-radius: 0 0 12 12;
                                         -fx-border-color: transparent;
                                         -fx-padding: 16 20;"/>
                    </VBox>

                </VBox>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
