<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.controllers.OwnerController"
            prefWidth="1366" prefHeight="768"
            style="-fx-background-color: #f4f6f9;">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--   TOP BAR — window controls only                       -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #141e2b;
                     -fx-min-height: 40; -fx-max-height: 40;">
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="—" onAction="#onMinimize"
                    style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d;
                           -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-padding: 0 12; -fx-cursor: hand;"/>
            <Button text="☐" onAction="#onMaximize"
                    style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-padding: 0 12; -fx-cursor: hand;"/>
            <Button text="✕" onAction="#onClose"
                    style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d;
                           -fx-font-size: 16px; -fx-font-weight: bold;
                           -fx-padding: 0 16 0 8; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <HBox style="-fx-background-color: #f4f6f9;">

            <!-- ═══════════════════════════════════════════════ -->
            <!--   SIDEBAR                                       -->
            <!-- ═══════════════════════════════════════════════ -->
            <VBox prefWidth="260" style="-fx-background-color: #1e2d40;">

                <VBox style="-fx-padding: 26 24 18 24;">
                    <Label text="🏠 RentEase"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </VBox>

                <Separator style="-fx-background-color: #2e4057;"/>

                <VBox style="-fx-padding: 18 24 8 24;">
                    <Label text="OWNER PORTAL"
                           style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;"/>
                </VBox>

                <VBox style="-fx-padding: 0 16 0 16;" spacing="8">

                    <!-- Products nav -->
                    <Button text="📋  My Product Listings"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2980b9; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: 600;
                                   -fx-background-radius: 10; -fx-padding: 13 18;
                                   -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"
                            onAction="#handleViewListings"/>

                    <!-- Reviews nav -->
                    <Button text="⭐  Reviews"
                            maxWidth="Infinity"
                            style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.72);
                                   -fx-font-size: 14px; -fx-font-weight: 600;
                                   -fx-background-radius: 10; -fx-padding: 13 18;
                                   -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"
                            onAction="#handleViewReviews"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox style="-fx-padding: 16;">
                    <Button fx:id="logoutBtn" text="⏻  Logout"
                            maxWidth="Infinity"
                            style="-fx-background-color: transparent; -fx-text-fill: #e74c3c;
                                   -fx-font-size: 14px; -fx-font-weight: 600;
                                   -fx-background-radius: 10; -fx-border-color: #e74c3c;
                                   -fx-border-width: 1.5; -fx-border-radius: 10;
                                   -fx-padding: 12 18; -fx-cursor: hand;"
                            onAction="#onLogoutClicked"/>
                </VBox>
            </VBox>

            <!-- ═══════════════════════════════════════════════ -->
            <!--   MAIN CONTENT AREA                             -->
            <!-- ═══════════════════════════════════════════════ -->
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #f4f6f9;">

                <!-- ─────────── PRODUCTS PAGE (default) ─────────── -->
                <VBox fx:id="productsPage" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #f4f6f9;">

                    <HBox style="-fx-background-color: white;
                                 -fx-padding: 22 32;
                                 -fx-border-color: #e1e8ed;
                                 -fx-border-width: 0 0 1 0;"
                          alignment="CENTER_LEFT">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label fx:id="welcomeLabel" text="Product Dashboard"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="Add, update, or remove your rental items"
                                   style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                        </VBox>
                        <Button text="+ Add New Product" prefHeight="43"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                       -fx-font-size: 14px; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-padding: 0 24;
                                       -fx-cursor: hand;"
                                onAction="#onAddProductClicked"/>
                    </HBox>

                    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 24 32;">
                        <VBox spacing="12" VBox.vgrow="ALWAYS"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 12;
                                     -fx-border-color: #e1e8ed;
                                     -fx-border-radius: 12; -fx-border-width: 1;">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Your Active Inventory"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <TextField fx:id="searchBar"
                                           promptText="Search your products..."
                                           prefWidth="250"
                                           style="-fx-background-radius: 8; -fx-padding: 8 12;"/>
                            </HBox>

                            <Separator/>

                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                        style="-fx-background-color: transparent;
                                               -fx-background: transparent;
                                               -fx-border-color: transparent;">
                                <VBox fx:id="productContainer" spacing="16" fillWidth="true">
                                    <padding><Insets top="8" bottom="8"/></padding>
                                </VBox>
                            </ScrollPane>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- ─────────── REVIEWS PAGE (hidden by default) ─────────── -->
                <VBox fx:id="reviewsPage" VBox.vgrow="ALWAYS"
                      visible="false" managed="false"
                      style="-fx-background-color: #f4f6f9;">

                    <!-- Header with avg rating badge -->
                    <HBox alignment="CENTER_LEFT" spacing="16"
                          style="-fx-background-color: white;
                                 -fx-padding: 22 32;
                                 -fx-border-color: #e1e8ed;
                                 -fx-border-width: 0 0 1 0;">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Reviews"
                                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="Manage your reviews and rate your renters"
                                   style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                        </VBox>
                        <VBox alignment="CENTER"
                              style="-fx-background-color: #fef5e7; -fx-background-radius: 10;
                                     -fx-padding: 10 18; -fx-border-color: #f39c12;
                                     -fx-border-width: 1; -fx-border-radius: 10;">
                            <Label fx:id="avgRatingLabel" text="⭐ — / 5"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                            <Label text="Your Average Rating"
                                   style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"/>
                        </VBox>
                    </HBox>

                    <!-- Two-column body -->
                    <HBox spacing="24" VBox.vgrow="ALWAYS" style="-fx-padding: 24 32;">

                        <!-- LEFT: Reviews Received -->
                        <VBox spacing="14" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-padding: 24;
                                     -fx-background-radius: 12;
                                     -fx-border-color: #e1e8ed; -fx-border-width: 1;
                                     -fx-border-radius: 12;">

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="📬 Reviews Received"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="reviewCountLabel" text="0 reviews"
                                       style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;
                                              -fx-background-color: #ecf0f1; -fx-padding: 5 12;
                                              -fx-background-radius: 20;"/>
                            </HBox>

                            <Separator style="-fx-background-color: #ecf0f1;"/>

                            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" prefHeight="380"
                                        style="-fx-background-color: transparent;
                                               -fx-background: transparent;
                                               -fx-border-color: transparent;">
                                <VBox fx:id="reviewContainer">
                                    <VBox fx:id="reviewBox" spacing="12" style="-fx-padding: 4;"/>
                                </VBox>
                            </ScrollPane>
                        </VBox>

                        <!-- RIGHT: Submit a Review -->
                        <VBox spacing="16" prefWidth="360" minWidth="320"
                              style="-fx-background-color: white; -fx-padding: 24;
                                     -fx-background-radius: 12;
                                     -fx-border-color: #2980b9; -fx-border-width: 2;
                                     -fx-border-radius: 12;">

                            <Label text="✍️ Rate a Renter"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Label text="Select a completed booking and leave a review."
                                   style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-wrap-text: true;"/>

                            <Separator style="-fx-background-color: #ecf0f1;"/>

                            <!-- Booking selector -->
                            <VBox spacing="6">
                                <Label text="Completed Booking"
                                       style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #34495e;"/>
                                <ChoiceBox fx:id="bookingChoice" maxWidth="Infinity"
                                           style="-fx-background-color: #f8f9fa;
                                                  -fx-background-radius: 8;
                                                  -fx-border-color: #dde1e7;
                                                  -fx-border-radius: 8; -fx-border-width: 1;
                                                  -fx-font-size: 13px;"/>
                                <Label text="Only completed bookings are shown."
                                       style="-fx-font-size: 10px; -fx-text-fill: #95a5a6;"/>
                            </VBox>

                            <!-- Star rating -->
                            <VBox spacing="6">
                                <Label text="Star Rating"
                                       style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #34495e;"/>
                                <HBox fx:id="starRatingBox" spacing="2" alignment="CENTER_LEFT">
                                    <Label text="★" fx:id="star1"
                                           style="-fx-font-size: 30px; -fx-text-fill: #bdc3c7; -fx-cursor: hand;"/>
                                    <Label text="★" fx:id="star2"
                                           style="-fx-font-size: 30px; -fx-text-fill: #bdc3c7; -fx-cursor: hand;"/>
                                    <Label text="★" fx:id="star3"
                                           style="-fx-font-size: 30px; -fx-text-fill: #bdc3c7; -fx-cursor: hand;"/>
                                    <Label text="★" fx:id="star4"
                                           style="-fx-font-size: 30px; -fx-text-fill: #bdc3c7; -fx-cursor: hand;"/>
                                    <Label text="★" fx:id="star5"
                                           style="-fx-font-size: 30px; -fx-text-fill: #bdc3c7; -fx-cursor: hand;"/>
                                </HBox>
                                <ChoiceBox fx:id="ratingChoice" visible="false" managed="false"
                                           maxWidth="0" maxHeight="0"/>
                                <Label fx:id="ratingHintLabel" text="Click a star to rate"
                                       style="-fx-font-size: 10px; -fx-text-fill: #95a5a6;"/>
                            </VBox>

                            <!-- Review text -->
                            <VBox spacing="6" VBox.vgrow="ALWAYS">
                                <Label text="Your Review"
                                       style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #34495e;"/>
                                <TextArea fx:id="reviewTextField"
                                          promptText="Describe your experience with this renter..."
                                          prefRowCount="5" wrapText="true"
                                          style="-fx-background-color: #f8f9fa;
                                                 -fx-background-radius: 8;
                                                 -fx-border-color: #dde1e7;
                                                 -fx-border-radius: 8; -fx-border-width: 1;
                                                 -fx-font-size: 13px; -fx-padding: 10;"/>
                                <Label fx:id="charCountLabel" text="0 / 500 characters"
                                       style="-fx-font-size: 10px; -fx-text-fill: #95a5a6;"/>
                            </VBox>

                            <!-- Status feedback -->
                            <Label fx:id="statusLabel" text="" wrapText="true"
                                   style="-fx-font-size: 12px; -fx-text-fill: #e74c3c;"/>

                            <!-- Submit -->
                            <Button fx:id="submitReviewBtn" text="Submit Review"
                                    onAction="#onSubmitReview" maxWidth="Infinity"
                                    style="-fx-background-color: #2980b9;
                                           -fx-text-fill: white; -fx-font-size: 14px;
                                           -fx-font-weight: bold; -fx-background-radius: 10;
                                           -fx-padding: 13 0; -fx-cursor: hand;"/>
                        </VBox>

                    </HBox>
                </VBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>
