<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="ui.controllers.BookingController" spacing="16" style="-fx-padding: 24; -fx-background-color: #ffffff; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4); -fx-background-radius: 12;">
    <Label fx:id="infoLabel" text="Booking info" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="From:" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="fromDate" styleClass="filter-dropdown"/>
        <Label text="To:" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="toDate" styleClass="filter-dropdown"/>
    </HBox>
    <Label fx:id="totalLabel" text="Total: $0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
    <Button fx:id="confirmBtn" text="Proceed to Payment" onAction="#onConfirm" styleClass="book-button"/>
</VBox>