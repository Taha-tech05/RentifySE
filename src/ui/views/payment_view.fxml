<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="ui.controllers.PaymentController" spacing="16" style="-fx-padding: 24; -fx-background-color: #ffffff; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4); -fx-background-radius: 12;">
    <Label text="Payment Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label fx:id="amountLabel" text="Amount: $0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Method:" style="-fx-font-weight: bold;"/>
        <ChoiceBox fx:id="methodChoice" styleClass="filter-dropdown"/>
    </HBox>
    <Button fx:id="payButton" text="Pay Now" onAction="#onPay" styleClass="book-button"/>
</VBox>