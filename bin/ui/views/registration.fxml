<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx" 
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.controllers.RegistrationController"
      spacing="15" alignment="CENTER">

    <!-- Padding defined using Insets -->
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Rentify - User Registration" style="-fx-font-size: 24px;"/>

    <TextField fx:id="nameField" promptText="Full Name"/>
    <TextField fx:id="emailField" promptText="Email"/>
    <PasswordField fx:id="passwordField" promptText="Password"/>
    <TextField fx:id="phoneField" promptText="Phone Number"/>

    <ChoiceBox fx:id="roleChoiceBox" prefWidth="200">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="ADMIN"/>
                <String fx:value="OWNER"/>
                <String fx:value="RENTER"/>
            </FXCollections>
        </items>
    </ChoiceBox>

    <Button text="Register" onAction="#onRegister"/>
    <Button text="Back to Login" onAction="#onBackToLogin"/>

</VBox>