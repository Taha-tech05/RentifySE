<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.controllers.AdminController"
            styleClass="root">

    <!-- ================= HEADER ================= -->
    <top>
        <HBox styleClass="header">
            <Label text="User Management" styleClass="logo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox styleClass="user-profile">
                <Label text="Admin"/>
                <StackPane styleClass="profile-avatar">
                    <Label text="A"/>
                </StackPane>
            </HBox>
        </HBox>
    </top>

    <!-- ================= CENTER CONTENT ================= -->
    <center>
        <VBox spacing="20">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

            <!-- Search + Refresh Bar -->
            <HBox styleClass="search-container" alignment="CENTER_LEFT">

                <Label text="🔍"/>

                <TextField fx:id="userSearchField"
                           promptText="Search by name or email..."
                           styleClass="search-field"
                           HBox.hgrow="ALWAYS"/>

                <Button text="Search"
                        onAction="#onSearchUsers"
                        styleClass="filter-button"/>

                <Button text="Refresh"
                        onAction="#onRefreshUsers"
                        styleClass="filter-button"/>
            </HBox>

            <!-- Users Table -->
            <TableView fx:id="usersTable"
                       VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="userIdCol"
                                 text="ID"
                                 prefWidth="70"/>

                    <TableColumn fx:id="userNameCol"
                                 text="Name"
                                 prefWidth="160"/>

                    <TableColumn fx:id="userEmailCol"
                                 text="Email"
                                 prefWidth="220"/>

                    <TableColumn fx:id="userPhoneCol"
                                 text="Phone"
                                 prefWidth="140"/>

                    <TableColumn fx:id="userRoleCol"
                                 text="Role"
                                 prefWidth="110"/>


                    <TableColumn fx:id="userActionCol"
                                 text="Actions"
                                 prefWidth="200"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>