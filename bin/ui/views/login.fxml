<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.controllers.LoginController"
            styleClass="root">

    <center>
        <VBox alignment="CENTER"
              spacing="24"
              style="-fx-padding: 40; -fx-alignment: center;">

            <Label text="Welcome to Rentify"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #4f46e5;"/>

            <ImageView fitWidth="120" fitHeight="120">
                <image>
                    <Image url="/ui/images/logo.png"/>
                </image>
            </ImageView>

            <VBox spacing="16" styleClass="center-box">

                <!-- Email -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Email:" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="emailField"
                               promptText="Enter your email"
                               styleClass="search-field"/>
                </HBox>

                <!-- Password -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Password:" style="-fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   styleClass="search-field"/>
                </HBox>

                <!-- Login Button -->
                <Button fx:id="loginButton"
                        text="Login"
                        onAction="#onLogin"
                        styleClass="filter-button"/>

            </VBox>
             <!-- Register button -->
    <Button text="Register" onAction="#onOpenRegistration"/>
        </VBox>
    </center>

</BorderPane>